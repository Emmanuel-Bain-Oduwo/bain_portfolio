# ── Database ─────────────────────────────────────────────────────────────────
# Railway injects this automatically when you attach a PostgreSQL service.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── SMTP / Email ──────────────────────────────────────────────────────────────
# For Google Workspace (emmanuelbain@kemirix.com), use an App Password:
#   Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=emmanuelbain@kemirix.com
SMTP_PASSWORD=your-google-app-password

# Where contact form submissions are delivered
CONTACT_EMAIL=emmanuelbain@kemirix.com
FROM_EMAIL=emmanuelbain@kemirix.com
FROM_NAME=Emmanuel Bain Oduwo Portfolio

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://www.bain.me